{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "astro.config.mjs",
    "drizzle/**/*.ts",
    "drizzle.config.ts",
    "src/**/*.ts"
  ],
  "exclude": ["dist", ".astro", "node_modules"]
}
