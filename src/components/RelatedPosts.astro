---
interface Props {
  links?: Array<{
    slug: string;
    title: string;
    description: string | null;
  }>;
}

const { links = [] } = Astro.props;
---

{links.length > 0 && (
  <aside class="post-links-section" aria-labelledby="related-posts-heading">
    <p class="archive-label archive-muted">Internal Links</p>
    <h2 id="related-posts-heading">Linked records</h2>
    <ul>
      {links.map((link) => (
        <li>
          <a href={`/posts/${link.slug}`}>{link.title}</a>
          {link.description && <p>{link.description}</p>}
        </li>
      ))}
    </ul>
  </aside>
)}
