---
import SeoHead from "./SeoHead.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "@/styles/global.css";
import { breadcrumbListJsonLd, websiteJsonLd, type BreadcrumbItem } from "@/lib/seo";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string | null;
  type?: "website" | "article";
  publishedTime?: string | null;
  modifiedTime?: string | null;
  structuredData?: unknown | unknown[];
  breadcrumbItems?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  type,
  publishedTime,
  modifiedTime,
  structuredData,
  breadcrumbItems
} = Astro.props;
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const pageStructuredData = [
  websiteJsonLd(),
  ...structuredDataItems,
  ...(breadcrumbItems && breadcrumbItems.length > 0 ? [breadcrumbListJsonLd(breadcrumbItems)] : [])
];
---

<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      structuredData={pageStructuredData}
    />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content antialiased">
    <Header />
    <div class="min-h-[calc(100vh-9rem)] py-12 sm:py-16">
      <slot />
    </div>
    <Footer />
  </body>
</html>
