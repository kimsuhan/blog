---
interface Props {
  overlay?: boolean;
  showNav?: boolean;
}

const { overlay = false, showNav = true } = Astro.props;
---

<header
  class:list={[
    "site-header flex items-center justify-between py-5 z-10",
    overlay ? "absolute top-0 inset-x-0 mx-auto border-none" : "border-b",
  ]}
>
  <a class="archive-label no-underline" href="/">Library Archive</a>
  {showNav && (
    <nav class="flex items-center gap-5">
      <a class="archive-label archive-muted hover:text-base-content" href="/search">Search</a>
    </nav>
  )}
</header>
