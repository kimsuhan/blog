---
import Layout from "@/components/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { listPublishedPosts } from "@/lib/post-store";

const posts = await listPublishedPosts();
---

<Layout title="Library Archive" description="Search-first Markdown knowledge archive" canonical="/">
  <main>
    <section class="archive-hero" aria-label="Search entry">
      <a class="search-symbol" href="/search" aria-label="Search archive">
        <span aria-hidden="true"></span>
      </a>
      <div class="scroll-cue" aria-hidden="true">
        <span></span>
        <small class="archive-label archive-muted">Scroll to explore the archive</small>
      </div>
    </section>

    <section class="archive-section container">
      <div class="section-heading">
        <h1>Recent Accessions</h1>
        <span class="archive-label archive-muted">{posts.length} records</span>
      </div>
      <div class="post-list">
        {posts.map((post) => (
          <PostCard
            title={post.metadata.title}
            slug={post.metadata.slug}
            description={post.metadata.description}
            date={post.metadata.date}
            series={post.metadata.series}
            tags={post.metadata.tags}
          />
        ))}
      </div>
    </section>
  </main>
</Layout>
