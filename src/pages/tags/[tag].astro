---
import Layout from "@/components/Layout.astro";
import PostCard from "@/components/PostCard.astro";
import { listPublishedPostsByTag } from "@/lib/post-store";

const { tag } = Astro.params;
const decodedTag = tag ? decodeURIComponent(tag) : "";
const posts = decodedTag ? await listPublishedPostsByTag(decodedTag) : [];
---

<Layout
  title={`Tag: ${decodedTag}`}
  description={`Published archive records tagged ${decodedTag}`}
  canonical={`/tags/${encodeURIComponent(decodedTag)}`}
  breadcrumbItems={[
    { name: "Home", url: "/" },
    { name: `Tag: ${decodedTag}`, url: `/tags/${encodeURIComponent(decodedTag)}` }
  ]}
>
  <main class="container">
    <section class="archive-section">
      <p class="archive-label archive-muted">Tag Index</p>
      <h1>#{decodedTag}</h1>
      <div class="post-list">
        {posts.map((post) => (
          <PostCard
            title={post.metadata.title}
            slug={post.metadata.slug}
            description={post.metadata.description}
            date={post.metadata.date}
            series={post.metadata.series}
            tags={post.metadata.tags}
          />
        ))}
      </div>
      {posts.length === 0 && <p class="archive-muted">No published records found.</p>}
    </section>
  </main>
</Layout>
